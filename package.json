{
  "name": "@soma/desktop",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:soma": "pnpm --filter soma run dev",
    "dev:tapia": "pnpm --filter tapia run dev",
    "docs:dev": "pnpm --filter @soma/docs run dev",
    "docs:build": "pnpm --filter @soma/docs run build",
    "docs:preview": "pnpm --filter @soma/docs run preview",
    "bundle:local": "pnpm --filter @soma/packaging run bundle",
    "typecheck": "pnpm --filter soma run typecheck && pnpm --filter tapia run typecheck",
    "lint": "pnpm --filter soma run lint && pnpm --filter tapia run lint",
    "format": "pnpm --filter soma run format && pnpm --filter tapia run format"
  },
  "workspaces": [
    "crates/wazuh-status-client"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "core-js",
      "core-js-pure",
      "electron",
      "electron-winstaller",
      "esbuild",
      "grpc-tools",
      "protobufjs",
      "sharp"
    ]
  }
}
